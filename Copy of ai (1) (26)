,"        else:\n","            print(f\"   - ⚠️ یافت نشد: {os.path.basename(f_path)}\")\n","\n","    if copied_count > 0:\n","        print(f\"\\n🎉 عملیات با موفقیت انجام شد. {copied_count} فایل در درایو ذخیره شدند.\")\n","    else:\n","        print(\"\\n❌ هیچ فایلی برای کپی پیدا نشد.\")\n","\n","# اجرای تابع بک آپ\n","backup_to_drive(MODEL_VERSION_NUMBER)"]},{"cell_type":"markdown","metadata":{"id":"54efd640"},"source":["### 💾 فایل Swap فعال شد!\n","\n","این کد یک فایل Swap به حجم 32 گیگابایت ایجاد و فعال کرد. فایل Swap به عنوان یک حافظه مجازی عمل می‌کند و در مواقعی که RAM سیستم پر می‌شود، داده‌ها را به هارد دیسک منتقل می‌کند. این کار به جلوگیری از کرش کردن محیط Colab به دلیل کمبود حافظه کمک می‌کند و پایداری عملیات‌های سنگین را افزایش می‌دهد."]},{"cell_type":"code","metadata":{"cellView":"form","id":"a0a7f4e3","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1782129395832,"user_tz":-210,"elapsed":559,"user":{"displayName":"mohammad khajavi","userId":"05559042646755348740"}},"outputId":"2f8c4776-244b-4b09-af5c-72ae07694c66"},"source":["# @title 💾 فعال‌سازی فایل Swap (32 گیگابایت برای پایداری بیشتر)\n","\n","# این کد یک فایل Swap به حجم 32 گیگابایت ایجاد و فعال می‌کند.\n","# فایل Swap به عنوان یک حافظه مجازی عمل می‌کند و در مواقعی که RAM سیستم پر می‌شود،\n","# داده‌ها را به هارد دیسک منتقل می‌کند. این کار به جلوگیری از کرش کردن محیط Colab\n","# به دلیل کمبود حافظه کمک می‌کند و پایداری عملیات‌های سنگین را افزایش می‌دهد.\n","\n","import os\n","\n","# Define swap file size in GB\n","SWAP_SIZE_GB = 32\n","SWAP_FILE_PATH = '/swapfile'\n","\n","print(f\"Creating a {SWAP_SIZE_GB}GB swap file...\")\n","# Create a large file for swap\n","!fallocate -l {SWAP_SIZE_GB}G {SWAP_FILE_PATH}\n","\n","# Set permissions for the swap file\n","!chmod 600 {SWAP_FILE_PATH}\n","\n","# Set up the Linux swap area\n","!mkswap {SWAP_FILE_PATH}\n","\n","# Activate the swap area\n","!swapon {SWAP_FILE_PATH}\n","\n","print(f\"\\nVerifying swap status...\")\n","# Verify that swap is active\n","!swapon --show"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Creating a 32GB swap file...\n","Setting up swapspace version 1, size = 32 GiB (34359734272 bytes)\n","no label, UUID=5c781b6c-341f-40be-adc3-f66d9fbf7414\n","swapon: /swapfile: swapon failed: Invalid argument\n","\n","Verifying swap status...\n"]}]},{"cell_type":"code","source":["import os, glob, gc, warnings\n","import numpy as np\n","import pandas as pd\n","import xgboost as xgb\n","from sklearn.model_selection import TimeSeriesSplit\n","from sklearn.metrics import average_precision_score\n","warnings.filterwarnings(\"ignore\")\n","\n","import io\n","import sys\n","from IPython.display import HTML, FileLink\n","\n","# -----------------------------------------------------------------------------\n","# ⚙️ تنظیمات ورودی — این‌ها رو با مقادیر واقعی پروژه‌ی خودت هماهنگ کن\n","# -----------------------------------------------------------------------------\n","DATA_DIR   = globals().get(\"DATA_DIR\", \"/content/hipo_lab_data\")\n","dataset_names = None          # None = همه‌ی فایل‌های *_Labeled.parquet موجود؛ یا لیست دستی بده\n","focus_class    = 1\n","n_folds        = 2 # Reduced from 5 to 2\n","purge_gap      = 1 # Reduced from 50 to 1\n","embargo_gap    = 1 # Reduced from 30 to 1\n","max_depth      = 5\n","lr             = 0.05\n","n_trees        = 300\n","stop_rounds    = 30\n","n_shuffles     = 15           # تعداد تکرار تست Label-Shuffle (هرچه بیشتر دقیق‌تر، ولی کندتر)\n","zero_frac_flag = 0.15         # آستانه‌ی هشدار برای fillna(0) contamination\n","\n","report_data = {\"✅\": [], \"⚠️\": [], \"❌\": []}\n","def verdict(level, text):\n","    report_data[level].append(text)\n","    # Print to both original stdout and captured stream\n","    original_stdout.write(f\"{level} {text}\\n\")\n","    captured_output.write(f\"{level} {text}\\n\")\n","\n","def wilson_ci(k, n, z=1.96):\n","    if n == 0: return (0.0, 0.0, 0.0)\n","    p = k / n\n","    denom = 1 + z**2 / n\n","    center = (p + z**2 / (2 * n)) / denom\n","    half = (z * np.sqrt((p * (1 - p) + z**2 / (4 * n)) / n)) / denom\n","    return p, max(0, center - half), min(1, center + half)\n","\n","def two_prop_ztest(k1, n1, k2, n2):\n","    if n1 == 0 or n2 == 0: return np.nan, np.nan\n","    p1, p2 = k1 / n1, k2 / n2\n","    p_pool = (k1 + k2) / (n1 + n2)\n","    se = np.sqrt(p_pool * (1 - p_pool) * (1 / n1 + 1 / n2))\n","    if se == 0: return 0.0, 1.0\n","    z = (p1 - p2) / se\n","    from math import erf, sqrt\n","    p_val = 2 * (1 - 0.5 * (1 + erf(abs(z) / sqrt(2))))\n","    return z, p_val\n","\n","# Redirect stdout to capture all print statements\n","original_stdout = sys.stdout\n","captured_output = io.StringIO()\n","sys.stdout = captured_output\n","\n","\n","print(\"=\" * 70)\n","print(\"🩺 HIPO DOCTOR — شروع تشخیص\")\n","print(\"=\" * 70)\n","\n","# -----------------------------------------------------------------------------\n","# 1) بارگذاری دیتا (دقیقاً به همون شکلی که سلول آموزش انجام می‌ده)\n","# -----------------------------------------------------------------------------\n","if dataset_names is None:\n","    dataset_names = [os.path.basename(f) for f in glob.glob(os.path.join(DATA_DIR, \"*_Labeled.parquet\"))]\n","if not dataset_names:\n","    raise RuntimeError(\"❌ هیچ فایل *_Labeled.parquet در DATA_DIR پیدا نشد.\")\n","\n","print(f\"\\n📁 دیتاست‌ها: {dataset_names}\")\n","dfs_raw = [pd.read_parquet(os.path.join(DATA_DIR, d)) for d in dataset_names]\n","df_raw = pd.concat(dfs_raw).sort_index()\n","\n","# -----------------------------------------------------------------------------\n","# 2) بخش ۱ — چک آلودگی fillna(0) / warm-up (قبل از fillna واقعی!)\n","# -----------------------------------------------------------------------------\n","print(\"\\n\" + \"-\" * 70)\n","print(\"🔬 بخش ۱: آلودگی fillna(0) روی فیچرهای پنجره‌ی بلند (Warm-up Contamination)\")\n","print(\"-\" * 70)\n","nan_frac = df_raw.isna().mean().sort_values(ascending=False)\n","top_nan = nan_frac[nan_frac > 0.001].head(20)\n","if len(top_nan) > 0:\n","    print(\"ستون‌هایی با درصد NaN قابل‌توجه (قبل از fillna):\")\n","    print(top_nan.to_string())\n","    verdict(\"⚠️\", f\"{len(nan_frac[nan_frac > 0.001])} ستون دارای NaN هستن که با fillna(0) به‌جای مقدار واقعی، صفر (احتمالاً بی‌معنی) می‌گیرن.\")\n","else:\n","    verdict(\"✅\", \"هیچ NaN قابل‌توجهی قبل از fillna پیدا نشد (این بخش تمیزه).\")\n","\n","# -----------------------------------------------------------------------------\n","# 3) آماده‌سازی دقیقاً مثل سلول آموزش (drop_list / split)\n","# -----------------------------------------------------------------------------\n","df = df_raw.fillna(0).replace([np.inf, -np.inf], 0)\n","drop_list = ['Target_Class', 'Signal_Dir', 'index', 'level_0', 'Time',\n","             'origin_time', 'origin_price', 'entry_price', 'M1_SL', 'M1_TP', 'M2_SL', 'M2_TP',\n","             'M3_SL', 'M3_TP', 'pair', 'max_bars', 'Raw_ATR', 'rev_cross_idx',\n","             'B_SL', 'B_TP', 'S_SL', 'S_TP', 'Open', 'High', 'Low', 'Close', 'Bid']\n","features = [c for c in df.columns if c not in drop_list and np.issubdtype(df[c].dtype, np.number)]\n","X = df[features].astype('float32')\n","y = (df['Target_Class'].astype(int) == int(focus_class)).astype(int)\n","\n","n_total = len(df)\n","final_idx = int(n_total * 0.70)\n","calib_start_idx = min(final_idx + embargo_gap, n_total)\n","calib_end_idx = min(int(n_total * 0.85), n_total)\n","oos_start_idx = min(calib_end_idx + embargo_gap, n_total)\n","X_cv, y_cv = X.iloc[:final_idx], y.iloc[:final_idx]\n","\n","print(f\"\\nکل نمونه‌ها: {n_total} | نرخ برد کلی (Base Rate): {y.mean():.3%}\")\n","print(f\"ناحیه‌ی CV: {len(X_cv)} ردیف | کالیبراسیون: {calib_end_idx - calib_start_idx} ردیف | تست نهایی: {n_total - oos_start_idx} ردیف\")\n","\n","# -----------------------------------------------------------------------------\n","# 4) بخش ۲ — چک Embargo/Purge Gap در برابر max_bars واقعی لیبل‌گذاری\n","# -----------------------------------------------------------------------------\n","print(\"\\n\" + \"-\" * 70)\n","print(\"🔬 بخش ۲: کفایت Embargo/Purge Gap نسبت به افق زمانی لیبل (max_bars)\")\n","print(\"-\" * 70)\n","if 'max_bars' in df_raw.columns:\n","    mb = df_raw['max_bars']\n","    mb = mb[mb > 0]\n","    mb_max = int(mb.max()) if len(mb) else None\n","    print(f\"max_bars مشاهده‌شده در دیتاست: min={mb.min() if len(mb) else '-'} | max={mb_max} | median={mb.median() if len(mb) else '-'}\")\n","    if mb_max is not None:\n","        if purge_gap < mb_max or embargo_gap < mb_max:\n","            verdict(\"❌\", f\"purge_gap({purge_gap})/embargo_gap({embargo_gap}) کوچیک‌تر از max_bars واقعی ({mb_max}) هستن → احتمال نشتِ لیبل نزدیک مرزها.\")\n","        else:\n","            verdict(\"✅\", f\"purge_gap/embargo_gap ({purge_gap}/{embargo_gap}) نسبت به max_bars ({mb_max}) کافی هستن.\")\n","else:\n","    verdict(\"⚠️\", \"ستون max_bars در دیتای لیبل‌شده پیدا نشد؛ این چک به‌صورت خودکار قابل انجام نبود — دستی چک کن.\")\n","\n","# -----------------------------------------------------------------------------\n","# 5) بخش ۳ — نرخ برد Buy در برابر Sell (چک عدم‌تقارن اسپرد/باگ جهت)\n","# -----------------------------------------------------------------------------\n","print(\"\\n\" + \"-\" * 70)\n","print(\"🔬 بخش ۳: تفاوت نرخ برد Buy در برابر Sell\")\n","print(\"-\" * 70)\n","if 'Signal_Dir' in df_raw.columns:\n","    buy_mask = df_raw['Signal_Dir'] == 1\n","    sell_mask = df_raw['Signal_Dir'] == -1\n","    yb = y[buy_mask.values]; ys = y[sell_mask.values]\n","    if len(yb) > 0 and len(ys) > 0:\n","        pb, lob, hib = wilson_ci(yb.sum(), len(yb))\n","        ps, los, his = wilson_ci(ys.sum(), len(ys))\n","        print(f\"BUY : n={len(yb):5d} | WinRate={pb:.3%}  (CI95%: {lob:.3%} - {hib:.3%})\")\n","        print(f\"SELL: n={len(ys):5d} | WinRate={ps:.3%}  (CI95%: {los:.3%} - {his:.3%})\")\n","        z, pval = two_prop_ztest(yb.sum(), len(yb), ys.sum(), len(ys))\n","        print(f\"تست تفاوت نسبت‌ها: z={z:.2f} | p-value={pval:.4f}\")\n","        if pval < 0.05:\n","            verdict(\"❌\", f\"تفاوت نرخ برد Buy/Sell از نظر آماری معنادار است (p={pval:.4f}) → به‌احتمال زیاد به‌خاطر عدم‌تقارن اسپرد در simulate_race_ps، یکی از دو جهت لیبل‌گذاری اریب (biased) شده.\")\n","        else:\n","            verdict(\"✅\", \"تفاوت نرخ برد Buy/Sell از نظر آماری معنادار نیست — این مسیر مشکوک منتفی شد.\")\n","    else:\n","        verdict(\"⚠️\", \"یکی از دو جهت (Buy/Sell) نمونه‌ی کافی نداشت.\")\n","else:\n","    verdict(\"⚠️\", \"ستون Signal_Dir پیدا نشد؛ این چک ممکن نبود.\")\n","\n","# -----------------------------------------------------------------------------\n","# 6) بخش ۴ — دریفت مفهومی در طول زمان (Concept Drift)\n","# -----------------------------------------------------------------------------\n","print(\"\\n\" + \"-\" * 70)\n","print(\"🔬 بخش ۴: ثبات نرخ برد در طول زمان (Concept Drift Check روی ناحیه‌ی CV)\")\n","print(\"-\" * 70)\n","thirds = np.array_split(y_cv.values, 3)\n","rates = []\n","for i, chunk in enumerate(thirds, 1):\n","    p, lo, hi = wilson_ci(chunk.sum(), len(chunk))\n","    rates.append(p)\n","    print(f\"  ثلث {i}: n={len(chunk):5d} | WinRate={p:.3%} (CI95%: {lo:.3%} - {hi:.3%})\")\n","z, pval = two_prop_ztest(int(thirds[0].sum()), len(thirds[0]), int(thirds[-1].sum()), len(thirds[-1]))\n","print(f\"تست تفاوت ثلث اول در برابر ثلث آخر: z={z:.2f} | p-value={pval:.4f}\")\n","if pval < 0.05:\n","    verdict(\"⚠️\", f\"نرخ برد بین ابتدا و انتهای بازه‌ی CV تفاوت معنادار داره (p={pval:.4f}) → احتمال drift/تغییر رژیم بازار در طول دیتا؛ مدل روی رفتار قدیمی‌تر آموزش می‌بینه که ممکنه دیگه صادق نباشه.\")\n","else:\n","    verdict(\"✅\", \"نرخ برد در طول ناحیه‌ی CV نسبتاً پایدار است (drift آشکاری دیده نشد).\")\n","\n","# -----------------------------------------------------------------------------\n","# 7) بخش ۵ — سیگنال‌های تکراری / ردیف‌های تکراری در فیچر\n","# -----------------------------------------------------------------------------\n","print(\"\\n\" + \"-\" * 70)\n","print(\"🔬 بخش ۵: بررسی ردیف‌ها/ایندکس‌های تکراری (باگ احتمالی در Signal Detection)\")\n","print(\"-\" * 70)\n","dup_idx = int(df.index.duplicated().sum())\n","dup_rows = int(X.duplicated().sum())\n","print(f\"ایندکس‌های تکراری: {dup_idx} | ردیف‌های فیچر کاملاً تکراری: {dup_rows} (از {len(X)})\")\n","if dup_idx > 0:\n","    verdict(\"⚠️\", f\"{dup_idx} ایندکس زمانی تکراری پیدا شد — ممکنه چند سیگنال هم‌زمان روی یک کندل ثبت شده باشن و بعضی رو خاموش کرده باشن.\")\n","if dup_rows > len(X) * 0.02:\n","    verdict(\"⚠️\", f\"{dup_rows} ردیف فیچر کاملاً یکسان (بیش از ۲٪ دیتا) — بررسی کن سیگنال‌دتکتور چند بار روی یک ستاپ سیگنال نمی‌ده.\")\n","if dup_idx == 0 and dup_rows <= len(X) * 0.02:\n","    verdict(\"✅\", \"مشکل قابل‌توجهی در تکراری‌بودن ردیف‌ها/ایندکس‌ها دیده نشد.\")\n","\n","# -----------------------------------------------------------------------------\n","# 8) بخش ۶ — مدل واقعی: PR-AUC واقعی + Feature Importance + همبستگی (MI-proxy)\n","# -----------------------------------------------------------------------------\n","print(\"\\n\" + \"-\" * 70)\n","print(\"🔬 بخش ۶: آموزش واقعی مدل (CV سریع) + اهمیت فیچرها\")\n","print(\"-\" * 70)\n","base_params = dict(max_depth=int(max_depth), learning_rate=float(lr), tree_method='hist',\n","                    booster='gbtree', objective='binary:logistic', eval_metric='aucpr',\n","                    random_state=42, n_jobs=-1)\n","\n","tscv = TimeSeriesSplit(n_splits=int(n_folds), gap=int(purge_gap))\n","real_aucs, last_model, last_split = [], None, None\n","for fold, (tr_idx, te_idx) in enumerate(tscv.split(X_cv), 1):\n","    X_tr = np.ascontiguousarray(X_cv.iloc[tr_idx], dtype=np.float32)\n","    y_tr = y_cv.iloc[tr_idx].values.astype(int)\n","    X_te = np.ascontiguousarray(X_cv.iloc[te_idx], dtype=np.float32)\n","    y_te = y_cv.iloc[te_idx].values.astype(int)\n","    spw = (y_tr == 0).sum() / ((y_tr == 1).sum() + 1e-9)\n","    m = xgb.XGBClassifier(**base_params, n_estimators=int(n_trees), scale_pos_weight=spw,\n","                           early_stopping_rounds=int(stop_rounds))\n","    m.fit(X_tr, y_tr, eval_set=[(X_te, y_te)], verbose=False)\n","    auc = average_precision_score(y_te, m.predict_proba(X_te)[:, 1])\n","    real_aucs.append(auc)\n","    last_model, last_split = m, (X_tr, y_tr, X_te, y_te)\n","    print(f\"  فولد {fold}: PR-AUC واقعی = {auc:.4f}  (Base Rate این فولد = {y_te.mean():.3%})\")\n","real_auc_mean = float(np.mean(real_aucs))\n","print(f\"میانگین PR-AUC واقعی: {real_auc_mean:.4f} ± {np.std(real_aucs):.4f}\")\n","\n","imp = pd.Series(last_model.feature_importances_, index=features).sort_values(ascending=False)\n","corr = X_cv.apply(lambda col: np.corrcoef(col.values, y_cv.values)[0, 1] if col.std() > 0 else 0.0)\n","corr = corr.abs().sort_values(ascending=False)\n","print(\"\\nTop 10 فیچر بر اساس Gain Importance مدل:\")\n","print(imp.head(10).to_string())\n","print(\"\\nTop 10 فیچر بر اساس همبستگی مطلق با هدف (Point-Biserial):\")\n","print(corr.head(10).to_string())\n","overlap = len(set(imp.head(15).index) & set(corr.head(15).index))\n","print(f\"\\nهم‌پوشانی بین دو لیست Top-15: {overlap}/15\")\n","if overlap <= 3:\n","    verdict(\"⚠️\", \"هم‌پوشانی کم بین Feature Importance و همبستگی خام → نشونه‌ی اینه که مدل احتمالاً داره روی نویز/تعامل‌های ناپایدار fit می‌کنه نه رابطه‌ی خطی/مستقیم قوی.\")\n","if corr.iloc[0] < 0.03:\n","    verdict(\"⚠️\", f\"حتی قوی‌ترین فیچر هم همبستگی خطی خیلی ضعیفی با هدف داره ({corr.iloc[0]:.4f}) → سیگنال موجود در فیچرها (حداقل به‌شکل خطی) خیلی ضعیفه.\")\n","\n","# -----------------------------------------------------------------------------\n","# 9) بخش ۷ — تست قطعی: Label-Shuffle Permutation Test\n","# -----------------------------------------------------------------------------\n","print(\"\\n\" + \"-\" * 70)\n","print(f\"🔬 بخش ۷: Label-Shuffle Test ({n_shuffles} تکرار) — آیا مدل واقعاً یاد می‌گیره؟\")\n","print(\"-\" * 70)\n","X_tr, y_tr, X_te, y_te = last_split  # از آخرین فولد بالا استفاده می‌کنیم\n","shuffled_aucs = []\n","rng = np.random.default_rng(42)\n","for i in range(n_shuffles):\n","    y_tr_shuf = rng.permutation(y_tr)\n","    spw = (y_tr_shuf == 0).sum() / ((y_tr_shuf == 1).sum() + 1e-9)\n","    m = xgb.XGBClassifier(**base_params, n_estimators=int(n_trees), scale_pos_weight=spw,\n","                           early_stopping_rounds=int(stop_rounds))\n","    m.fit(X_tr, y_tr_shuf, eval_set=[(X_te, y_te)], verbose=False)\n","    auc = average_precision_score(y_te, m.predict_proba(X_te)[:, 1])  # y_te واقعی و شافل‌نشده می‌مونه\n","    shuffled_aucs.append(auc)\n","    gc.collect()\n","\n","shuffled_aucs = np.array(shuffled_aucs)\n","real_last_auc = real_aucs[-1]\n","p_value = float((shuffled_aucs >= real_last_auc).mean())\n","print(f\"PR-AUC واقعی (همون فولد آخر): {real_last_auc:.4f}\")\n","print(f\"PR-AUC توزیع Null (لیبل شافل‌شده): میانگین={shuffled_aucs.mean():.4f} ± {shuffled_aucs.std():.4f} | max={shuffled_aucs.max():.4f}\")\n","print(f\"p-value (احتمال اینکه نویز به‌تنهایی به این عملکرد برسه): {p_value:.4f}\")\n","if p_value > 0.10:\n","    verdict(\"❌\", f\"مدل واقعی از نظر آماری از مدل‌های تصادفی/شافل‌شده قابل‌تمایز نیست (p={p_value:.3f}) → این قوی‌ترین شاهده که فعلاً مدل رابطه‌ی معناداری بین فیچرها و لیبل پیدا نکرده؛ مشکل به‌احتمال زیاد از جنس «سیگنال ضعیف/تعریف پترن» است، نه صرفاً تنظیمات مدل.\")\n","elif p_value > 0.03:\n","    verdict(\"⚠️\", f\"نتیجه مرزیه (p={p_value:.3f}) — شاید یه مقدار سیگنال واقعی وجود داره ولی خیلی ضعیفه؛ با دیتای بیشتر/فیچر بهتر دوباره تست کن.\")\n","else:\n","    verdict(\"✅\", f\"مدل واقعی به‌طور معناداری بهتر از توزیع نویز عمل می‌کنه (p={p_value:.3f}) → یه رابطه‌ی واقعی (هرچند ضعیف) بین فیچرها و لیبل هست؛ مسیر درست بهبود، تقویت فیچر/افزایش دیتاست هست نه شکار باگ.\")\n","\n","# -----------------------------------------------------------------------------\n","# 10) بخش ۸ — کالیبراسیون با فاصله‌ی اطمینان روی هر باکت (چک صحت اعداد \"دقت بالا\")\n","# -----------------------------------------------------------------------------\n","print(\"\\n\" + \"-\" * 70)\n","print(\"🔬 بخش ۸: جدول کالیبراسیون واقعی با فاصله‌ی اطمینان (روی همون فولد آخر)\")\n","print(\"-\" * 70)\n","proba = last_model.predict_proba(X_te)[:, 1]\n","bins = [0, 0.3, 0.4, 0.5, 0.6, 0.7, 0.8, 1.01]\n","bin_ids = np.digitize(proba, bins) - 1\n","print(f\"{'باکت احتمال':<18}{'n':>6}{'WinRate':>12}{'CI95% پایین':>14}{'CI95% بالا':>14}\")\n","for b in range(len(bins) - 1):\n","    mask = bin_ids == b\n","    n_b = int(mask.sum())\n","    if n_b == 0:\n","        continue\n","    k_b = int(y_te[mask].sum())\n","    p, lo, hi = wilson_ci(k_b, n_b)\n","    label = f\"{bins[b]:.2f}-{bins[b+1]:.2f}\"\n","    print(f\"{label:<18}{n_b:>6}{p:>11.2%}{lo:>13.2%}{hi:>13.2%}\")\n","    if n_b < 30:\n","        verdict(\"⚠️\", f\"باکت احتمال {label} فقط {n_b} نمونه داره — هر عددی که از این باکت می‌بینی (مثلاً 33٪ در برابر 35٪) عملاً داخل نویز آماریه و قابل‌اتکا نیست.\")\n","\n","# -----------------------------------------------------------------------------\n","# 📋 گزارش نهایی\n","# -----------------------------------------------------------------------------\n","print(\"\\n\" + \"=\" * 70)\n","print(\"📋 خلاصه‌ی گزارش نهایی HIPO DOCTOR\")\n","print(\"=\" * 70)\n","for level in [\"❌\", \"⚠️\", \"✅\"]:\n","    if report_data[level]:\n","        print(f\"\\n{level} ({len(report_data[level])} مورد):\")\n","        for i, msg in enumerate(report_data[level], 1):\n","            print(f\"   {i}. {msg}\")\n","print(\"\\n\" + \"=\" * 70)\n","print(\"توصیه: اول مواردِ ❌ رو رفع کن، بعد ⚠️ ها رو بررسی کن. اگه بخش ۷ (Label-Shuffle)\")\n","print(\"نتیجه‌ی ❌ داد، تمرکز رو از تیونینگ مدل بردار و ببر روی خودِ تعریف پترن/فیچرها.\")\n","print(\"=\" * 70)\n","\n","# Restore stdout\n","sys.stdout = original_stdout\n","console_output_str = captured_output.getvalue()\n","\n","# --- HTML Report Generation ---\n","html_content = f\"\"\"\n","<!DOCTYPE html>\n","<html lang=\"fa\">\n","<head>\n","    <meta charset=\"UTF-8\">\n","    <title>HI